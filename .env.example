# Copy to .env and fill in real values. .env is gitignored.

ANTHROPIC_API_KEY=

# Splunk management endpoint (host:port of the REST API).
SPLUNK_HOST=localhost:8089

# --- Splunk MCP backend ---------------------------------------------------- #
# official  = the official Splunk MCP Server app (Splunkbase 7931) over HTTP at
#             https://<SPLUNK_HOST>/services/mcp  (default; needs SPLUNK_MCP_TOKEN)
# livehybrid = the community livehybrid/splunk-mcp stdio server (fallback;
#             needs SPLUNK_USERNAME/SPLUNK_PASSWORD + SPLUNK_MCP_DIR)
OPS_MCP_BACKEND=official

# Bearer token for the official Splunk MCP Server (create in Splunk; the role
# needs the mcp_tool_execute capability). Required when OPS_MCP_BACKEND=official.
SPLUNK_MCP_TOKEN=
# Optional: override the full MCP URL (default derived from SPLUNK_HOST).
# SPLUNK_MCP_URL=https://localhost:8089/services/mcp

# Used only by the livehybrid fallback backend:
SPLUNK_USERNAME=
SPLUNK_PASSWORD=
# SPLUNK_MCP_DIR=/path/to/livehybrid/splunk-mcp

# TLS verification for the Splunk connection (default off for local self-signed).
VERIFY_SSL=false
